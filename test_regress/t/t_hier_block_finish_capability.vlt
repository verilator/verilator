`verilator_config
verilator_lib -module "AliasedCanonicalWrapper"
verilator_lib -module "AliasedNearMissWrapper"
no_finish -hier-dpi "aliased_canonical_c"
// The SV alias must not be accepted in place of the canonical C symbol.
no_finish -hier-dpi "aliased_near_miss_sv"
