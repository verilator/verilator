        module fsm_if_mixed_vars_bad (
%000007     input logic clk
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1,
            S2 = 2'd2
          } state_t;
        
%000001   state_t state_q  /*verilator fsm_state*/;
%000000   state_t other_q;
%000001   state_t state_d;
        
%000008   always_comb begin
%000008     state_d = state_q;
%000001     if (state_q == S0) state_d = S1;
%000007     else if (other_q == S1) state_d = S2;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_one_branch_bad (
%000007     input logic clk
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1
          } state_t;
        
%000001   state_t state_q  /*verilator fsm_state*/;
%000001   state_t state_d;
        
%000008   always_comb begin
%000008     state_d = state_q;
%000007     if (state_q == S0) state_d = S1;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_duplicate_bad (
%000007     input logic clk
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1
          } state_t;
        
%000001   state_t state_q  /*verilator fsm_state*/;
%000001   state_t state_d;
        
%000008   always_comb begin
%000008     state_d = state_q;
%000001     if (state_q == S0) state_d = S1;
%000007     else if (state_q == S0) state_d = S0;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_two_comparisons_bad (
%000007     input logic clk,
%000000     input logic start
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1,
            S2 = 2'd2
          } state_t;
        
%000000   state_t state_q  /*verilator fsm_state*/;
%000000   state_t state_d;
        
%000008   always_comb begin
%000008     state_d = state_q;
%000008     if ((state_q == S0) && (state_q == S1)) state_d = S2;
%000008     else if (state_q == S1) state_d = S0;
          end
        
%000007   always_ff @(posedge clk) state_q <= start ? state_d : state_q;
        endmodule
        
        module fsm_if_or_bad (
%000007     input logic clk
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1,
            S2 = 2'd2
          } state_t;
        
%000004   state_t state_q  /*verilator fsm_state*/;
%000004   state_t state_d;
        
%000008   always_comb begin
%000008     state_d = state_q;
%000004     if ((state_q == S0) || (state_q == S1)) state_d = S2;
%000004     else if (state_q == S2) state_d = S0;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_alias_guard_bad (
%000007     input logic clk,
%000000     input logic start
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1,
            S2 = 2'd2
          } state_t;
        
%000000   logic idle_state;
%000000   state_t state_q  /*verilator fsm_state*/;
%000000   state_t state_d;
        
 000022   always_comb begin
 000022     state_d = state_q;
~000022     idle_state = (state_q == S0) && start;
%000000     if (idle_state) state_d = S1;
~000022     else if (state_q == S1) state_d = S2;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_ambiguous_alias_bad (
%000007     input logic clk
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1,
            S2 = 2'd2
          } state_t;
        
%000000   logic idle_state;
%000000   state_t state_q  /*verilator fsm_state*/;
%000000   state_t state_d;
        
%000008   always_comb begin
%000008     state_d = state_q;
%000008     idle_state = (state_q == S0);
%000008     idle_state = (state_q == S1);
%000008     idle_state = (state_q == S2);
%000000     if (idle_state) state_d = S2;
%000008     else if (state_q == S2) state_d = S0;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_missing_default_bad (
%000007     input logic clk
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1,
            S2 = 2'd2
          } state_t;
        
%000001   state_t state_q  /*verilator fsm_state*/;
%000001   state_t state_d;
        
%000001   always_comb begin
%000001     state_d = S0;
%000001     if (state_d == S0) state_d = S1;
%000000     else if (state_d == S1) state_d = S2;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_no_assign_bad (
%000007     input logic clk
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1
          } state_t;
        
%000001   logic flag;
%000000   state_t state_q  /*verilator fsm_state*/;
%000000   state_t state_d;
        
%000008   always_comb begin
%000008     flag = 1'b0;
%000008     state_d = state_q;
%000008     if (state_q == S0) flag = 1'b1;
%000000     else if (state_q == S1) state_d = S0;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_nonvar_compare_bad (
%000007     input logic clk
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1
          } state_t;
        
%000004   state_t state_q  /*verilator fsm_state*/;
%000004   state_t state_d;
        
%000008   always_comb begin
%000008     state_d = state_q;
%000004     if ((state_q + 2'd0) == S0) state_d = S1;
        // [FSM coverage]
%000004        // [fsm_arc t.nonvar_compare_u.state_q::S0->S1]
%000003        // [fsm_arc t.nonvar_compare_u.state_q::S1->S0]
%000003        // [fsm_state t.nonvar_compare_u.state_q::S0]
%000004        // [fsm_state t.nonvar_compare_u.state_q::S1]
%000004     else if (state_q == S1) state_d = S0;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_var_rhs_compare_bad (
%000007     input logic clk
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1
          } state_t;
        
%000001   state_t state_q  /*verilator fsm_state*/;
%000001   state_t state_d;
        
%000008   always_comb begin
%000008     state_d = state_q;
%000008     if (state_q == state_d) state_d = S1;
%000000     else if (state_q == S1) state_d = S0;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_alias_other_state_bad (
%000007     input logic clk
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1
          } state_t;
        
%000001   logic idle_state;
%000001   state_t state_q  /*verilator fsm_state*/;
%000000   state_t other_q;
%000001   state_t state_d;
        
%000008   always_comb begin
%000008     state_d = state_q;
%000008     idle_state = (state_q == S0);
%000008     idle_state = (other_q == S0);
%000008     if (idle_state) state_d = S1;
%000000     else if (state_q == S1) state_d = S0;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_bit_or_bad (
%000007     input logic clk,
%000000     input logic start
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1,
            S2 = 2'd2
          } state_t;
        
%000001   state_t state_q  /*verilator fsm_state*/;
%000001   state_t state_d;
        
 000022   always_comb begin
 000022     state_d = state_q;
~000019     if ((state_q == S0) | start) state_d = S1;
~000016     else if (state_q == S1) state_d = S2;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module fsm_if_reduction_bad (
%000007     input logic clk
        );
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1,
            S2 = 2'd2
          } state_t;
        
%000004   state_t state_q  /*verilator fsm_state*/;
%000004   state_t state_d;
        
%000008   always_comb begin
%000008     state_d = state_q;
%000008     if (&state_q) state_d = S1;
%000004     else if (state_q == S1) state_d = S2;
%000004     if (|state_q) state_d = S2;
%000004     else if (state_q == S2) state_d = S0;
%000004     if (^state_q) state_d = S0;
%000004     else if (state_q == S0) state_d = S1;
          end
        
%000007   always_ff @(posedge clk) state_q <= state_d;
        endmodule
        
        module t (
%000007     input logic clk,
%000000     input logic start
        );
          integer cyc;
        
          fsm_if_mixed_vars_bad mixed_vars_u (.clk(clk));
          fsm_if_one_branch_bad one_branch_u (.clk(clk));
          fsm_if_duplicate_bad duplicate_u (.clk(clk));
          fsm_if_two_comparisons_bad two_comparisons_u (.clk(clk), .start(start));
          fsm_if_or_bad or_u (.clk(clk));
          fsm_if_alias_guard_bad alias_guard_u (.clk(clk), .start(start));
          fsm_if_ambiguous_alias_bad ambiguous_alias_u (.clk(clk));
          fsm_if_missing_default_bad missing_default_u (.clk(clk));
          fsm_if_no_assign_bad no_assign_u (.clk(clk));
          fsm_if_nonvar_compare_bad nonvar_compare_u (.clk(clk));
          fsm_if_var_rhs_compare_bad var_rhs_compare_u (.clk(clk));
          fsm_if_alias_other_state_bad alias_other_state_u (.clk(clk));
          fsm_if_bit_or_bad bit_or_u (.clk(clk), .start(start));
          fsm_if_reduction_bad reduction_u (.clk(clk));
        
%000001   initial cyc = 0;
        
%000007   always @(posedge clk) begin
%000007     cyc <= cyc + 1;
%000006     if (cyc == 6) begin
%000001       $write("*-* All Finished *-*\n");
%000001       $finish;
            end
          end
        endmodule
        
