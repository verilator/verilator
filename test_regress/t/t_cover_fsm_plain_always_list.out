        // SPDX-FileCopyrightText: 2026 Wilson Snyder
        // SPDX-License-Identifier: CC0-1.0
        
        module t (
            input clk
        );
        
          typedef enum logic [1:0] {
            S0 = 2'd0,
            S1 = 2'd1,
            S2 = 2'd2
          } state_t;
        
          integer cyc;
          logic rst;
          logic start;
          state_t state_q;
          state_t state_d;
        
          initial begin
            rst = 1'b1;
            start = 1'b0;
            cyc = 0;
          end
        
          always @(posedge clk) begin
            cyc <= cyc + 1;
            if (cyc == 1) rst <= 1'b0;
            if (cyc == 2) start <= 1'b1;
            if (cyc == 3) start <= 1'b0;
            if (cyc == 6) begin
              $write("*-* All Finished *-*\n");
              $finish;
            end
          end
        
          always @(state_q or start) begin
            state_d = state_q;
%000003     case (state_q)
        // [FSM coverage]
%000001        // [fsm_arc t.state_q::ANY->S0[reset]] [reset arc, excluded from %]
%000000        // [fsm_arc t.state_q::S0->S1]
%000003        // [fsm_arc t.state_q::S0->S2]
%000002        // [fsm_state t.state_q::S0]
%000000        // [fsm_state t.state_q::S1] *** UNCOVERED ***
%000003        // [fsm_state t.state_q::S2]
              S0: state_d = start ? S1 : S2;
              default: state_d = S0;
            endcase
          end
        
          always_ff @(posedge clk) begin
            if (rst) state_q <= S0;
            else state_q <= state_d;
          end
        
        endmodule
        
