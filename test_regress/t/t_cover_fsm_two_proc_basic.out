        // SPDX-License-Identifier: CC0-1.0
        
        module t (
            input clk
        );
        
          typedef enum logic [1:0] {
            S_IDLE = 2'd0,
            S_RUN  = 2'd1,
            S_DONE = 2'd2,
            S_ERR  = 2'd3
          } state_t;
        
          logic rst;
          logic start;
          integer cyc;
          state_t state_q /*verilator fsm_reset_arc*/;
          state_t state_d;
        
          initial begin
            rst = 1'b1;
            start = 1'b0;
            cyc = 0;
          end
        
          always @(posedge clk) begin
            cyc <= cyc + 1;
            if (cyc == 1) rst <= 1'b0;
            if (cyc == 2) start <= 1'b1;
            if (cyc == 3) start <= 1'b0;
            if (cyc == 8) begin
              $write("*-* All Finished *-*\n");
              $finish;
            end
          end
        
          always_comb begin
            state_d = state_q;
%000001     case (state_q)
        // [FSM coverage]
%000001        // [fsm_arc t.state_q::ANY->S_IDLE[reset_include]] [reset arc, excluded from %]
%000001        // [fsm_arc t.state_q::S_RUN->S_DONE]
%000001        // [fsm_state t.state_q::S_DONE]
%000001        // [fsm_state t.state_q::S_ERR]
%000000        // [fsm_state t.state_q::S_IDLE] *** UNCOVERED ***
%000001        // [fsm_state t.state_q::S_RUN]
              S_IDLE: if (start) state_d = S_RUN;
              S_RUN: state_d = S_DONE;
              default: state_d = S_ERR;
            endcase
          end
        
          always_ff @(posedge clk) begin
            if (rst) state_q <= S_IDLE;
            else state_q <= state_d;
          end
        
        endmodule
        
